{
    "name": "<website-slug>/root",
    "version": "1.0.0",
    "description": "this composer is for init a repo at ROOT for composer+jblank+wp subdirectory project. ",
    "require": {
        "php": ">=8.2",
        "composer/installers": ">=2.0",
        "johnpbloch/wordpress": ">=6.0",
        "jengo-agency/<website-repo-slug>": "dev-master",
        "jen-go/wp-muplugin-loader": "*",
        "composer-runtime-api": "^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "installer-paths": {
            "wp-content/themes/{$name}/": ["type:wordpress-theme"],
            "wp-content/mu-plugins/{$name}/": ["type:wordpress-muplugin"]
        },
        "wordpress-install-dir": "wp"
    },
    "repositories": [
        {
            "packagist.org": false
        },
        {
            "type": "vcs",
            "url": "git@github.com:jengo-agency/<website-repo-slug>",
            "only": ["jengo-agency/*"]
        },
        {
            "type": "composer",
            "url": "https://wpackagist.org",
            "only": ["wpackagist-plugin/*", "wpackagist-theme/*"]
        },
        {
            "type": "composer",
            "url": "https://jengo.repo.repman.io",
            "exclude": ["wpackagist-plugin/*", "wpackagist-theme/*", "jengo-control/*"]
        },
        {
            "type": "composer",
            "url": "https://control.jengo.website/satispress/",
            "only": ["jengo-control/*"]
        }
    ],
    "config": {
        "preferred-install": {
            "type:wordpress-theme": "source",
            "jengo-agency/*": "source"
        },
        "require-all": true,
        "store-auths": true,
        "allow-plugins": {
            "composer/installers": true,
            "johnpbloch/wordpress-core-installer": true,
            "jengo-agency/jblank-composer-plugin": true,
            "jen-go/wp-muplugin-loader": true
        },
        "http-basic": {
            "jengo.repo.repman.io": {
                "username": "token",
                "password": "xxx"
            }
        }
    },
    "autoload": {
        "classmap": ["wp-content/themes/jblank/functions/composer/"]
    }
}
